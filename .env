RESBOT_MODEL_NAME=google/flan-t5-large

RESBOT_MAX_NEW_TOKENS=256


# Deterministic by default for training stability

RESBOT_DO_SAMPLE=0

RESBOT_TEMPERATURE=0.0

RESBOT_TOP_P=0.9


RESBOT_LOG_LEVEL=INFO


# System instructions (editable without changing code)

RESBOT_SYSTEM_PROMPT=You are ResilienceBot, an SRE troubleshooting assistant.


# Dynamic context (lab uses env, later labs will supply retrieved context)

RESBOT_CONTEXT=Environment: API Gateway + upstream service + database. Use logs/metrics/traces/config.


# ===== Day 2 Lab 1: RAG Pipeline =====
RESBOT_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
RESBOT_DOCS_DIR=data/docs
RESBOT_INDEX_DIR=data/index
RESBOT_CHUNK_SIZE=200
RESBOT_CHUNK_OVERLAP=40
RESBOT_RETRIEVAL_TOP_K=3
